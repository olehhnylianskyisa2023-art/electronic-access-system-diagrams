@startuml
!define DIRECTION top to bottom
skinparam backgroundColor #FEFEFE
skinparam stateBackgroundColor #E0F2F1
skinparam stateBorderColor #00695C
skinparam ArrowColor #004D40

title Діаграма станів\nСистема контролю доступу

[*] --> Очікування

Очікування --> Сканування : студент підходить
Сканування --> Обробка : камера готова

Обробка --> Дозвіл : обличчя розпізнано
Обробка --> Заборона : обличчя невпізнано
Обробка --> Невідомо : помилка розпізнавання

Дозвіл --> Відкриття : видати дозвіл
Відкриття --> Очікування : студент пройшов

Заборона --> Тривога : видати сигнал
Тривога --> Очікування : тривога скасована

Невідомо --> Очікування : перезавантаження

@enduml